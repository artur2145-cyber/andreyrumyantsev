# Copy to .env (local) or add these in Vercel → Settings → Environment Variables.

# Anthropic API key for the AI assistant (api/chat.ts). Without it the chat
# shows a friendly "not connected yet" message instead of real answers.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-opus-4-8. Use claude-haiku-4-5 for a cheaper,
# faster assistant.
ANTHROPIC_MODEL=claude-opus-4-8
